---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const extractFileNumber = (id: string) => {
  const match = id.match(/(\d+)/);
  return match ? Number(match[1]) : 0;
};

const releases = (await getCollection('press-releases'))
  .filter((release) => /^\d+\.md$/.test(release.id))
  .sort((a, b) => extractFileNumber(b.id) - extractFileNumber(a.id));
---

<MainLayout>
  <main class="bg-gray-900 text-white max-w-7xl mx-auto px-4 sm:px-6 py-6">
    <h1 class="text-3xl sm:text-4xl font-bold mb-3">Press Releases</h1>
    <p class="text-gray-300 mb-8">Latest official announcements from Milling & Millers.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {releases.map((release) => (
        <a href={`/press-releases/${release.id.replace(/\.md$/, '')}`} class="block bg-gray-800 border border-gray-700 rounded-lg overflow-hidden hover:bg-gray-750 transition">
          {release.data.cardImage && (
            <img src={release.data.cardImage} alt={release.data.title} class="w-full h-48 object-cover" loading="lazy" />
          )}
          <div class="p-4">
            <div class="text-xs uppercase tracking-wide text-gray-400 mb-2">
              {release.data.publishDate.toLocaleDateString()}
            </div>
            <h2 class="text-lg font-semibold leading-snug">{release.data.title}</h2>
            <p class="mt-2 text-sm text-gray-300 line-clamp-3">{release.data.summary}</p>
            <span class="inline-block mt-4 text-sm text-indigo-300">Read release</span>
          </div>
        </a>
      ))}
    </div>
  </main>
</MainLayout>
