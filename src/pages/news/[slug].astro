---
import MainLayout from "../../layouts/MainLayout.astro";
import { newsPosts } from "../../data/news.js";

export async function getStaticPaths() {
  return newsPosts.map((post) => ({
    params: { slug: post.slug },
  }));
}

// Use Astro.params to resolve the post for this page
const { slug } = Astro.params;
const post = newsPosts.find((p) => p.slug === slug);
---
<MainLayout>
  <main class="bg-gray-900 text-white max-w-4xl mx-auto p-4">
    {post ? (
      <>
        <h1 class="text-4xl font-bold mb-4">{post.title}</h1>
        {post.image && <img src={post.image} alt={post.title} class="w-full h-auto object-cover mb-4 rounded" />}
        <div class="prose prose-invert max-w-none">
          <p>{post.content}</p>
        </div>
      </>
    ) : (
      <div class="text-center py-20">
        <h1 class="text-3xl font-bold mb-2">404 — Not found</h1>
        <p class="text-gray-300">We couldn't find that article.</p>
      </div>
    )}
  </main>
</MainLayout>
