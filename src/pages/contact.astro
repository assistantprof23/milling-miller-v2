---
import MainLayout from "../layouts/MainLayout.astro";
---
<MainLayout>
  <main class="bg-gray-900 text-white max-w-3xl md:max-w-7xl mx-auto px-4 sm:px-6 py-6">
    <h1 class="text-2xl sm:text-3xl font-bold mb-4">Contact</h1>

    <p class="text-gray-300 mb-6">We’d love to hear from you. Reach out via phone or email and we’ll get back to you shortly.</p>

    <section class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Contact Info (replaces the previous form) -->
      <aside class="bg-gray-800 p-4 sm:p-6 rounded shadow text-gray-200">
        <h2 class="text-xl font-semibold mb-3">Get in touch</h2>

        <div class="mb-4">
          <h3 class="font-medium text-gray-200 mb-1">Phone</h3>
          <p class="text-green-300 text-lg"><a href="tel:+15551234567" class="hover:underline">+1 (555) 123-4567</a></p>
        </div>

        <div class="mb-4">
          <h3 class="font-medium text-gray-200 mb-1">Email</h3>
          <p class="text-green-300 text-lg"><a href="mailto:info@example.com" class="hover:underline">info@example.com</a></p>
        </div>

        <p class="text-sm text-gray-400 mt-4">Business hours: Mon–Fri: 9:00 AM — 5:00 PM</p>
      </aside>

      <!-- Additional details or location -->
      <div class="bg-gray-800 p-4 sm:p-6 rounded shadow text-gray-200">
        <h2 class="text-xl font-semibold mb-3">Office</h2>
        <p class="text-gray-300 mb-4">123 Mill Lane<br/>Springfield, Country</p>

        <!-- ...existing code... -->
      </div>
    </section>
  </main>
</MainLayout>
