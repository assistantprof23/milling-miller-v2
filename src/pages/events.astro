---
import MainLayout from "../layouts/MainLayout.astro";
import EventsGrid from '../components/EventsGrid.astro';
import { events } from "../data/events.js";
---
<MainLayout>
  <main class="bg-[#0b1221] text-white">

      <!-- homepage-style hero -->
      <section class="relative">
        <div class="absolute inset-0">
          <img src="https://meetingtomorrow.com/wp-content/uploads/2019/08/What-Size-Projector-Screen-For-Events.jpg" alt="Events hero" class="w-full h-full object-cover opacity-30" />
          <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#0b1221]/90"></div>
        </div>

        <div class="relative max-w-7xl mx-auto px-6 py-28">
          <div class="max-w-3xl">
            <div class="inline-flex items-center px-3 py-1 rounded-full bg-indigo-700 text-sm font-medium text-indigo-100 mb-4">News & Events</div>
            <h1 class="text-4xl sm:text-5xl font-extrabold leading-tight">Upcoming events, workshops and seminars</h1>
            <p class="mt-4 text-gray-300">Stay up to date with practical workshops, demonstrations and summits for mill operators and industry professionals. Find trainings, equipment demos and networking events near you.</p>
            <div class="mt-6 flex flex-wrap gap-3">
              <a href="#events" class="inline-flex items-center px-4 py-2 bg-indigo-600 hover:bg-indigo-500 rounded-md text-sm font-medium">Browse events</a>
              <a href="mailto:events@example.com" class="inline-flex items-center px-4 py-2 border border-gray-700 rounded-md text-sm text-gray-200 hover:bg-gray-800">List an event</a>
            </div>
          </div>
        </div>
      </section>

      <!-- content: two-column with events grid + sidebar -->
      <section id="events" class="max-w-7xl mx-auto px-6 py-12">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
          <!-- main column -->
          <div class="lg:col-span-2">
            <!-- keep EventsGrid but ensure spacing aligns with homepage -->
            <EventsGrid events={events} />
          </div>

          <!-- sidebar -->
          <aside class="space-y-6">
            <!-- search -->
            <div class="bg-[#0f1724] border border-gray-800 p-4 rounded-md">
              <label class="block text-sm font-medium text-gray-300 mb-2">Search events</label>
              <div class="flex gap-2">
                <input placeholder="Search by title, location or organizer" class="flex-1 px-3 py-2 bg-[#071025] border border-gray-800 rounded-md text-sm text-gray-200 focus:outline-none" />
                <button class="px-3 py-2 bg-indigo-600 rounded-md text-sm font-medium">Search</button>
              </div>
            </div>

            <!-- featured event (use the first event) -->
            <div class="bg-[#0f1724] border border-gray-800 rounded-md overflow-hidden">
              <div class="p-4">
                <div class="text-xs text-indigo-300 font-semibold mb-2">Featured</div>
                <h3 class="text-lg font-bold">Rice Processing Best Practices Workshop</h3>
                <p class="mt-2 text-sm text-gray-300">A practical workshop covering modern rice processing techniques, quality control and fortification best practices for mill operators.</p>
                <div class="mt-3 text-sm text-gray-400">10 Mar 2026 · New Delhi</div>
                <a href="#" class="mt-4 inline-block px-4 py-2 bg-indigo-600 rounded-md text-sm font-medium">View details</a>
              </div>
              <div class="h-32 bg-cover bg-center" style="background-image: url('https://www.millingandmillers.com/wp-content/uploads/2023/05/Indiana-Automation-04.jpg')"></div>
            </div>

            <!-- CTA / newsletter -->
            <div class="bg-[#0f1724] border border-gray-800 p-4 rounded-md">
              <h4 class="text-sm font-semibold">Get event updates</h4>
              <p class="mt-2 text-sm text-gray-300">Subscribe to receive updates about upcoming workshops and demos.</p>
              <div class="mt-3 flex gap-2">
                <input placeholder="Your email" class="flex-1 px-3 py-2 bg-[#071025] border border-gray-800 rounded-md text-sm text-gray-200" />
                <button class="px-3 py-2 bg-indigo-600 rounded-md text-sm font-medium">Subscribe</button>
              </div>
            </div>
          </aside>
        </div>
      </section>

  </main>
</MainLayout>