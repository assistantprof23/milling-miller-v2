---
const year = new Date().getFullYear();
const socialLinks = [
  { name: 'Facebook', href: 'https://facebook.com/millingandmillers', short: 'f' },
  { name: 'X', href: 'https://x.com/millingandmillers', short: 'x' },
  { name: 'Instagram', href: 'https://instagram.com/millingandmillers', short: 'ig' },
  { name: 'YouTube', href: 'https://youtube.com/@millingandmillers', short: 'yt' },
];
---
<footer class="bg-gray-900 border-t border-gray-800 text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-7 sm:py-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-5">
    <div class="w-full sm:w-auto text-center sm:text-left">
      <div class="text-white font-semibold">Milling & Millers</div>
      <div class="text-sm text-gray-400 mt-1">Keeping the industry informed — news, events and equipment updates.</div>
    </div>

    <div class="text-sm text-gray-400 w-full sm:w-auto text-center sm:text-left">
      <div class="mb-3">
        <div class="text-xs uppercase tracking-[0.08em] text-gray-500 mb-2">Follow us</div>
        <div class="grid grid-cols-2 sm:flex sm:flex-wrap items-center gap-2">
          {socialLinks.map((item) => (
            <a
              href={item.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Follow on ${item.name}`}
              class="inline-flex justify-center sm:justify-start items-center gap-2 rounded-md border border-gray-700 bg-gray-800/70 px-2.5 py-1.5 text-xs font-semibold text-gray-200 hover:bg-gray-700 transition"
            >
              <span class="inline-flex h-5 min-w-5 items-center justify-center rounded bg-gray-700 px-1 text-[10px] uppercase">{item.short}</span>
              <span>{item.name}</span>
            </a>
          ))}
        </div>
      </div>
      <div>Contact: <a class="text-indigo-300 hover:underline" href="mailto:info@example.com">info@example.com</a></div>
      <div class="mt-2">© {year} Milling & Millers</div>
    </div>
  </div>
</footer>

