---
import { newsPosts } from '../data/news.js';
const latest = newsPosts.slice(0, 3);
---
<section class="max-w-7xl mx-auto py-16 px-6">
  <h2 class="text-3xl font-bold mb-8">Market Highlights</h2>

  <div class="grid md:grid-cols-3 gap-8">
    {latest.map((post) => (
      <div class="bg-white p-6 rounded-xl shadow hover:shadow-lg transition">
        <div
          class="w-full h-40 rounded-md mb-4 bg-cover bg-center"
          style={`background-image: url('${post.image ?? '/default-image.jpg'}')`}
          role="img"
          aria-label={post.title}
        />
        <h3 class="text-xl font-semibold mb-2 text-green-700">{post.title}</h3>
        <p class="text-gray-600 mb-4">
          {post.content ? (post.content.length > 120 ? post.content.slice(0, 117) + '...' : post.content) : ''}
        </p>
        <a href={`/news/${post.slug}`} class="text-green-600 font-medium">
          Read more →
        </a>
      </div>
    ))}
  </div>
</section>