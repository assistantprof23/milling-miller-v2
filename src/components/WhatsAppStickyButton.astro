---
import ads from "../data/ads.json";
---

<a
  href={ads.whatsapp.href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={ads.whatsapp.alt}
  class="wa-sticky"
>
  <svg viewBox="0 0 32 32" width="26" height="26" fill="currentColor" aria-hidden="true">
    <path d="M16.04 5.333c-5.86 0-10.624 4.697-10.624 10.472 0 1.846.486 3.647 1.408 5.24L5.333 26.667l5.806-1.468a10.69 10.69 0 0 0 4.901 1.182h.005c5.86 0 10.622-4.698 10.622-10.472 0-2.8-1.126-5.437-3.17-7.422-2.01-1.95-4.676-3.154-7.457-3.154Zm0 19.286a8.93 8.93 0 0 1-4.52-1.234l-.325-.194-3.447.871.92-3.36-.212-.342a8.61 8.61 0 0 1-1.334-4.554c0-4.8 3.98-8.706 8.918-8.706 2.34 0 4.646.974 6.323 2.672 1.7 1.722 2.636 3.985 2.636 6.367 0 4.8-3.98 8.706-8.918 8.706Zm4.89-6.531c-.267-.132-1.583-.773-1.829-.86-.247-.088-.425-.132-.603.132-.178.265-.691.86-.848 1.036-.156.176-.313.198-.58.066-.267-.132-1.129-.41-2.15-1.308-.795-.699-1.332-1.56-1.488-1.824-.156-.264-.016-.407.118-.538.121-.12.267-.31.401-.463.134-.154.178-.264.267-.44.09-.175.045-.33-.022-.462-.067-.132-.602-1.452-.825-1.988-.218-.523-.44-.452-.603-.46l-.513-.01c-.178 0-.468.066-.713.33-.245.264-.936.915-.936 2.232s.958 2.587 1.092 2.763c.134.176 1.886 2.86 4.57 4.009.639.275 1.138.44 1.527.563.642.204 1.226.175 1.688.106.514-.078 1.583-.646 1.806-1.271.223-.624.223-1.16.156-1.27-.067-.11-.245-.176-.512-.308Z" />
  </svg>
</a>

<style>
  .wa-sticky {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    width: 54px;
    height: 54px;
    border-radius: 999px;
    background: #25d366;
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 24px rgba(9, 23, 14, 0.28);
    z-index: 80;
    transition: transform 160ms ease, box-shadow 160ms ease;
  }

  .wa-sticky:hover {
    transform: translateY(-2px) scale(1.03);
    box-shadow: 0 14px 28px rgba(9, 23, 14, 0.32);
  }

  @media (min-width: 768px) {
    .wa-sticky {
      right: 1.25rem;
      bottom: 1.25rem;
      width: 58px;
      height: 58px;
    }
  }
</style>
