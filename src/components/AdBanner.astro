---
const {
  href = '#',
  imageSrc,
  alt = 'Sponsored advertisement',
  label = 'Sponsored',
  containerClass = '',
} = Astro.props;
---

<div class={`ad-banner ${containerClass}`.trim()}>
  <span class="ad-label">{label}</span>
  <a href={href} class="ad-link" target="_blank" rel="noopener noreferrer" aria-label={alt}>
    <img src={imageSrc} alt={alt} loading="lazy" class="ad-image" />
  </a>
</div>

<style>
  .ad-banner {
    width: 100%;
  }

  .ad-label {
    display: inline-block;
    margin-bottom: 0.35rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.45);
    background: rgba(255, 255, 255, 0.72);
    color: #334155;
    padding: 0.12rem 0.5rem;
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .ad-link {
    display: block;
    border-radius: 0.55rem;
    overflow: hidden;
    border: 1px solid rgba(148, 163, 184, 0.35);
    background: #ffffff;
  }

  .ad-image {
    width: 100%;
    height: auto;
    max-height: 170px;
    object-fit: contain;
    display: block;
    transition: transform 180ms ease;
  }

  .ad-link:hover .ad-image {
    transform: scale(1.01);
  }

  @media (max-width: 640px) {
    .ad-image {
      max-height: 120px;
    }
  }
</style>
