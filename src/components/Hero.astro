---
import ads from "../data/ads.json";
---

<section class="relative isolate overflow-hidden bg-[#eef4ea]">
  <div class="absolute inset-0 pointer-events-none hero-atmosphere" aria-hidden="true"></div>

  <div class="mx-auto grid max-w-7xl gap-8 px-4 py-12 sm:px-6 sm:py-14 md:grid-cols-2 md:items-center md:px-12 md:py-24">
    <div>
      <p class="hero-chip">India’s Leading Milling, Grain & Biofuel Industry Platform</p>
      <h1 class="hero-reveal text-3xl font-extrabold leading-tight text-[#15331a] sm:text-4xl md:text-5xl">
        Better milling outcomes, from policy updates to machinery choices.
      </h1>
      <p class="hero-reveal hero-delay-1 mt-5 max-w-xl text-base leading-relaxed text-[#35553b] sm:text-lg">
        One lightweight hub for rice mill operators to track events, evaluate equipment, and act on market and compliance signals.
      </p>

      <div class="hero-reveal hero-delay-2 mt-7 flex flex-wrap gap-3">
        <a href="/machinery" class="hero-cta-primary">Explore Machinery</a>
        <a href="/events" class="hero-cta-secondary">See Upcoming Events</a>
      </div>

      
    </div>

    <div class="hero-reveal hero-delay-2">
      <div class="hero-visual-shell">
        <aside class="hero-ad" aria-label="Sponsored advertisement">
          <div class="hero-ad-label">Sponsored</div>
          <a href={ads.hero.href} target="_blank" rel="noopener noreferrer" class="hero-ad-link" aria-label={ads.hero.alt}>
            <img src={ads.hero.imageSrc} alt={ads.hero.alt} loading="lazy" class="hero-ad-image" />
          </a>
        </aside>
      </div>
    </div>
  </div>

  <style>
    .hero-atmosphere {
      background:
        radial-gradient(circle at 82% 20%, rgba(102, 170, 95, 0.24), transparent 45%),
        radial-gradient(circle at 15% 80%, rgba(241, 182, 77, 0.16), transparent 40%);
    }

    .hero-chip {
      display: inline-flex;
      margin-bottom: 0.9rem;
      border: 1px solid rgba(18, 56, 29, 0.15);
      background: rgba(255, 255, 255, 0.7);
      border-radius: 999px;
      padding: 0.3rem 0.7rem;
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-weight: 700;
      color: #2d5a36;
    }

    .hero-reveal {
      opacity: 0;
      transform: translateY(10px);
      animation: heroFade 700ms cubic-bezier(.2,.85,.25,1) forwards;
    }

    .hero-delay-1 { animation-delay: 110ms; }
    .hero-delay-2 { animation-delay: 220ms; }
    .hero-delay-3 { animation-delay: 320ms; }

    .hero-cta-primary,
    .hero-cta-secondary {
      display: inline-flex;
      justify-content: center;
      align-items: center;
      border-radius: 0.5rem;
      padding: 0.72rem 1.05rem;
      font-size: 0.9rem;
      font-weight: 700;
      transition: transform .16s ease, box-shadow .16s ease, background-color .16s ease;
    }

    .hero-cta-primary {
      background: #1f6a33;
      color: #fff;
      box-shadow: 0 10px 26px rgba(31, 106, 51, 0.22);
    }

    .hero-cta-primary:hover {
      transform: translateY(-2px);
      background: #1a5b2c;
    }

    .hero-cta-secondary {
      border: 1px solid rgba(23, 53, 30, 0.2);
      background: #fff;
      color: #1e4024;
    }

    .hero-cta-secondary:hover {
      transform: translateY(-2px);
      background: #f8fbf6;
    }

    .stat-pill {
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(23, 53, 30, 0.11);
      border-radius: 999px;
      padding: 0.38rem 0.72rem;
      backdrop-filter: blur(2px);
    }

    .hero-visual-shell {
      display: grid;
      gap: 0.85rem;
    }

    .hero-visual {
      position: relative;
      overflow: hidden;
      min-height: 230px;
      border-radius: 1rem;
      border: 1px solid rgba(18, 56, 29, 0.15);
      box-shadow: 0 18px 40px rgba(14, 46, 27, 0.16);
      background: #12391f;
    }

    .hero-visual-image {
      width: 100%;
      height: 100%;
      min-height: 230px;
      object-fit: cover;
      display: block;
    }

    .hero-visual-overlay {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      padding: 1rem;
      background: linear-gradient(to top, rgba(9, 23, 14, 0.86), rgba(9, 23, 14, 0));
      color: #eff8ee;
    }

    .visual-kicker {
      display: inline-flex;
      border-radius: 999px;
      background: rgba(173, 233, 170, 0.18);
      border: 1px solid rgba(173, 233, 170, 0.28);
      color: #d4f0cf;
      padding: 0.2rem 0.55rem;
      font-size: 0.66rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin: 0;
    }

    .hero-visual-overlay h2 {
      margin: 0.5rem 0 0;
      font-size: 1.12rem;
      line-height: 1.3;
      font-weight: 800;
      color: #ffffff;
    }

    .hero-visual-overlay p {
      margin: 0.45rem 0 0;
      font-size: 0.82rem;
      color: #d2e6d4;
    }

    .hero-ad {
      border-radius: 0.75rem;
      border: 1px solid rgba(18, 56, 29, 0.12);
      background: rgba(255, 255, 255, 0.72);
      padding: 0.45rem;
      box-shadow: 0 10px 24px rgba(14, 46, 27, 0.12);
    }

    .hero-ad-label {
      display: inline-block;
      margin-bottom: 0.35rem;
      border-radius: 999px;
      border: 1px solid rgba(28, 73, 37, 0.2);
      background: rgba(242, 247, 239, 0.92);
      color: #33533a;
      padding: 0.15rem 0.5rem;
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .hero-ad-link {
      display: block;
      border-radius: 0.5rem;
      overflow: hidden;
      border: 1px solid rgba(28, 73, 37, 0.14);
    }

    .hero-ad-image {
      width: 100%;
      height: auto;
      display: block;
      object-fit: contain;
      background: #fff;
      transition: transform 180ms ease;
    }

    .hero-ad-link:hover .hero-ad-image {
      transform: scale(1.01);
    }

    @keyframes heroFade {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .hero-reveal,
      .hero-ad-image {
        animation: none !important;
        opacity: 1;
        transform: none;
      }

      .hero-cta-primary,
      .hero-cta-secondary {
        transition: none;
      }
    }

    @media (max-width: 640px) {
      .hero-chip {
        margin-bottom: 0.75rem;
      }

      .hero-cta-primary,
      .hero-cta-secondary {
        width: 100%;
      }

      .stat-pill {
        font-size: 0.78rem;
      }

      .hero-visual-overlay {
        padding: 0.75rem;
      }

      .hero-visual-overlay h2 {
        font-size: 1rem;
      }

      .hero-visual-overlay p {
        font-size: 0.76rem;
      }
    }

    @media (min-width: 768px) {
      .hero-visual,
      .hero-visual-image {
        min-height: 340px;
      }
    }
  </style>
</section>